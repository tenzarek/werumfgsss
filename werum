local Button = MainTab:CreateButton({
	Name = "есп оружия (beta)",
	Callback = function()     
		-- Настройки
		local highlightThickness = 10 -- Толщина обводки
		local depthMode = Enum.HighlightDepthMode.AlwaysOnTop -- Подсветка сквозь объекты
		local showNames = false -- Отображать имена предметов
		local rainbowSpeed = 1 -- Скорость смены цветов (чем больше, тем быстрее)

		-- Функция для создания подсветки
		local function CreateHighlight(object)
			local highlight = Instance.new("Highlight")
			highlight.Parent = object
			highlight.OutlineThickness = highlightThickness
			highlight.DepthMode = depthMode
			return highlight
		end

		-- Функция для удаления подсветки
		local function RemoveHighlight(object)
			local highlight = object:FindFirstChild("Highlight")
			if highlight then
				highlight:Destroy()
			end
		end

		-- Функция для создания надписи над объектом
		local function CreateNameLabel(object)
			local billboardGui = Instance.new("BillboardGui")
			billboardGui.Parent = object
			billboardGui.Size = UDim2.new(100, 1000, 100000, 100) -- Ширина 100%, высота 20%
			billboardGui.StudsOffset = Vector3.new(0, 2, 5) -- Смещение над объектом
			billboardGui.AlwaysOnTop = true

			local textLabel = Instance.new("TextLabel")
			textLabel.Parent = billboardGui
			textLabel.Size = UDim2.new(1, 0, 1, 0) -- Занимает всю область BillboardGui
			textLabel.BackgroundTransparency = 1
			textLabel.TextColor3 = Color3.new(1, 0, 0.94902) -- Белый цвет текста
			textLabel.TextScaled = true
			textLabel.Text = "FUCKNIGGERS"-- Имя объекта
			textLabel.Font = Enum.Font.SourceSansBold
			textLabel.TextStrokeColor3 = Color3.new(1, 0, 0.917647)
			textLabel.TextStrokeTransparency = 0
			return billboardGui
		end

		-- Функция для удаления надписи
		local function RemoveNameLabel(object)
			local billboardGui = object:FindFirstChild("BillboardGui")
			if billboardGui then
				billboardGui:Destroy()
			end
		end

		-- Функция для вычисления радужного цвета
		local function GetRainbowColor(offset)
			local hue = (tick() * rainbowSpeed + offset) % 360
			return Color3.fromHSV(hue / 360, 1, 1)
		end

		-- Функция для обработки добавления новых предметов в Workspace
		local function OnDescendantAdded(descendant)
			if descendant:IsA("Tool") then
				local highlight = CreateHighlight(descendant)
				if showNames then
					CreateNameLabel(descendant)
				end
				-- Запоминаем highlight для обновления цвета
				descendant:SetAttribute("HighlightInstance", highlight)
			end
		end

		-- Функция для обработки удаления предметов из Workspace
		local function OnDescendantRemoving(descendant)
			if descendant:IsA("Tool") then
				RemoveHighlight(descendant)
				RemoveNameLabel(descendant)
			end
		end

		-- Функция для начальной подсветки существующих предметов
		local function HighlightExistingTools()
			for _, object in pairs(workspace:GetDescendants()) do
				if object:IsA("Tool") then
					local highlight = CreateHighlight(object)
					if showNames then
						CreateNameLabel(object)
					end
					-- Запоминаем highlight для обновления цвета
					object:SetAttribute("HighlightInstance", highlight)
				end
			end
		end

		-- Подключаем события для обработки добавления и удаления предметов
		workspace.DescendantAdded:Connect(OnDescendantAdded)
		workspace.DescendantRemoving:Connect(OnDescendantRemoving)

		-- Выполняем начальную подсветку существующих предметов
		HighlightExistingTools()

		-- Функция для обновления радужной подсветки
		local function UpdateRainbowHighlights()
			for _, object in pairs(workspace:GetDescendants()) do
				if object:IsA("Tool") then
					local highlight = object:GetAttribute("HighlightInstance")
					if highlight then
						local offset = tonumber(string.sub(tostring(object), 11, 14), 16) or 0
						local rainbowColor = GetRainbowColor(offset)
						highlight.FillColor = rainbowColor
						highlight.OutlineColor = rainbowColor
					end
				end
			end
		end

		-- Обновляем радужную подсветку каждый кадр
		game:GetService("RunService").RenderStepped:Connect(UpdateRainbowHighlights)

		print("Радужный ВХ на Tool предметы в Workspace активирован.")
	end,
})

