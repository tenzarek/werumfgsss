				-- Проверяем состояние каждые 5 секунд
				if tick() - lastCheck > 5 then
					if not IsOn() then
						print("🔄 Рация отключилась, восстанавливаем...")
						EnsureOn()
					end
					lastCheck = tick()
				end

				-- Отправляем сообщение
				pcall(function()
					RADIO:InvokeServer(3, MSG .. " #" .. count)
				end)

				count = count + 1

				-- Каждые 50 сообщений показываем счетчик
				if count % 50 == 0 then
					print("📨 Отправлено: " .. count)
				end

				task.wait(0.02)
			end
