		local CH = 12
		local RUN = true
		local RADIO = ReplicatedStorage:FindFirstChild("rems").functions.RadioAction

		-- Функция проверки наличия рации
		local function HasRadio()
			return (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Рация")) or 
				LocalPlayer.Backpack:FindFirstChild("Рация")
		end

		-- Функция проверки включена ли рация
		local function IsOn()
			local radio = HasRadio()
			if radio then
				local state = radio:FindFirstChild("CurState")
				return state and state.Value
			end
			return false
		end

		-- Функция гарантированного включения
		local function EnsureOn()
			if not HasRadio() then
				print("⚠️ Рация не найдена!")
				return false
			end

			-- Пытаемся включить
			pcall(function() RADIO:InvokeServer(1) end)
			wait(0.2)

			-- Проверяем
			for i = 1, 5 do
				if IsOn() then
					pcall(function() RADIO:InvokeServer(2, CH) end)
					wait(0.1)
					return true
				end
				wait(0.1)
			end

			return false
		end

		print("🔄 Активация...")

		if EnsureOn() then
			print("✅ Рация готова, начинаю спам")

			local count = 0
			local lastCheck = tick()

