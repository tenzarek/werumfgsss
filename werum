	-- Буква W (розовая)
	local letterW = Instance.new("TextLabel")
	letterW.Name = "LetterW"
	letterW.Size = UDim2.new(0, 130, 1, 0)
	letterW.Position = UDim2.new(0, 0, 0, 0)
	letterW.BackgroundTransparency = 1
	letterW.Text = "W"
	letterW.TextColor3 = Color3.fromRGB(255, 105, 180) -- Розовый
	letterW.TextSize = 100
	letterW.TextTransparency = 1
	letterW.TextXAlignment = Enum.TextXAlignment.Right
	letterW.Font = Enum.Font.GothamBold
	letterW.Parent = mainTextContainer
	
	-- Вторая часть (белая)
	local secondPart = Instance.new("TextLabel")
	secondPart.Name = "SecondPart"
	secondPart.Size = UDim2.new(0, 570, 1, 0)
	secondPart.Position = UDim2.new(0, 130, 0, 0) -- Сразу после W
	secondPart.BackgroundTransparency = 1
	secondPart.Text = "ERUMFGSSSHAB" -- Без АБ в конце, чтобы было как в примере
	secondPart.TextColor3 = Color3.new(1, 1, 1)
	secondPart.TextSize = 100
	secondPart.TextTransparency = 1
	secondPart.TextXAlignment = Enum.TextXAlignment.Left
	secondPart.Font = Enum.Font.GothamBold
	secondPart.Parent = mainTextContainer
	
	-- Нижний текст
	local bottomText = Instance.new("TextLabel")
	bottomText.Name = "BottomText"
	bottomText.Size = UDim2.new(0, 400, 0, 40)
	bottomText.Position = UDim2.new(0.5, -200, 0.5, 60) -- Центрируем отдельно
	bottomText.BackgroundTransparency = 1
	bottomText.Text = "лутши чит на зе дурка"
	bottomText.TextColor3 = Color3.new(1, 1, 1)
	bottomText.TextSize = 30
	bottomText.TextTransparency = 1
	bottomText.Font = Enum.Font.Gotham
	bottomText.Parent = textContainer
	
	-- Настройки анимаций
	local fadeInInfo = TweenInfo.new(2, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
	local textAppearInfo = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local waitTime = 3
	
	-- Создаем твины
	local fadeToBlack = TweenService:Create(blackFrame, fadeInInfo, {BackgroundTransparency = 0})
	local fadeExtraBlack = TweenService:Create(extraBlack, fadeInInfo, {BackgroundTransparency = 0})
	
	local showW = TweenService:Create(letterW, textAppearInfo, {TextTransparency = 0})
	local showSecond = TweenService:Create(secondPart, textAppearInfo, {TextTransparency = 0})
	local showBottom = TweenService:Create(bottomText, fadeInInfo, {TextTransparency = 0})
	
	-- Функция для принудительного полного затемнения
	local function forceFullBlack()
		blackFrame.BackgroundTransparency = 0
		extraBlack.BackgroundTransparency = 0
		-- Дополнительно проверяем размеры
		blackFrame.Size = UDim2.new(1, 0, 1, 0)
		extraBlack.Size = UDim2.new(1, 0, 1, 0)
	end
	
	-- Функция для исчезновения
	local function startFadeOut()
		local fadeOutW = TweenService:Create(letterW, fadeInInfo, {TextTransparency = 1})
		local fadeOutSecond = TweenService:Create(secondPart, fadeInInfo, {TextTransparency = 1})
		local fadeOutBottom = TweenService:Create(bottomText, fadeInInfo, {TextTransparency = 1})
		local fadeOutBlack = TweenService:Create(blackFrame, fadeInInfo, {BackgroundTransparency = 1})
		local fadeOutExtra = TweenService:Create(extraBlack, fadeInInfo, {BackgroundTransparency = 1})
		
		fadeOutW:Play()
		fadeOutSecond:Play()
		fadeOutBottom:Play()
		fadeOutBlack:Play()
		fadeOutExtra:Play()
		
		fadeOutBlack.Completed:Connect(function()
			screenGui:Destroy()
		end)
	end
	
	-- Главная последовательность
	local function playIntro()
		-- Сброс прозрачности
		letterW.TextTransparency = 1
		secondPart.TextTransparency = 1
		bottomText.TextTransparency = 1
		blackFrame.BackgroundTransparency = 1
		extraBlack.BackgroundTransparency = 1
		
		-- Обновляем позицию на случай изменения размера экрана
		local currentScreenSize = workspace.CurrentCamera.ViewportSize
		local newCenterX = (currentScreenSize.X / 2) - (totalTextWidth / 2)
		mainTextContainer.Position = UDim2.new(0, newCenterX, 0, centerY)
		
		-- 1. ПОЛНОЕ ЗАТЕМНЕНИЕ (гарантированно)
		fadeToBlack:Play()
		fadeExtraBlack:Play()
		fadeToBlack.Completed:Wait()
		
		-- Принудительно делаем черным
		forceFullBlack()
		task.wait(0.1) -- Маленькая пауза для надежности
		
		-- 2. Появление W
		showW:Play()
		showW.Completed:Wait()
		
		-- 3. Появление второй части
		showSecond:Play()
		showSecond.Completed:Wait()
		
		-- 4. Появление нижнего текста
		showBottom:Play()
		showBottom.Completed:Wait()
		
		-- 5. Пауза
		task.wait(waitTime)
		
		-- 6. Исчезновение
		startFadeOut()
	end
	
	-- Запускаем
	task.wait(0.5)
	playIntro()
	
	-- Обновляем позицию при изменении размера окна (на всякий случай)
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
		local currentScreenSize = workspace.CurrentCamera.ViewportSize
		local newCenterX = (currentScreenSize.X / 2) - (totalTextWidth / 2)
		mainTextContainer.Position = UDim2.new(0, newCenterX, 0, centerY)
	end)
	
else
	warn("Этот скрипт должен быть запущен на клиенте (например, в LocalScript).")
end
