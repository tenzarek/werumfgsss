		-- Скрипт для запуска/остановки анимации (для инжектора)
		-- Переключение по кнопке G

		local animationId = "rbxassetid://181526230" -- ID анимации
		local player = game.Players.LocalPlayer
		local character = player.Character or player.CharacterAdded:Wait()
		local humanoid = character:WaitForChild("Humanoid")
		local UserInputService = game:GetService("UserInputService")

		local animationTrack
		local animationIsPlaying = false

		local function PlayAnimation()
			if not humanoid then
				warn("Humanoid не найден. Убедитесь, что персонаж загружен.")
				return
			end

			-- Останавливаем текущую анимацию, если она есть
			if animationTrack then
				animationTrack:Stop()
				animationTrack:Destroy()
				animationTrack = nil
				animationIsPlaying = false -- Обновляем флаг
			end

			-- Загружаем анимацию
			local animation = Instance.new("Animation")
			animation.AnimationId = animationId
			animation.Name = "CustomAnimation"

			-- Загружаем AnimationTrack
			animationTrack = humanoid:LoadAnimation(animation)

			-- Воспроизводим анимацию
			animationTrack:Play()
			animationIsPlaying = true -- Обновляем флаг
		end

		local function StopAnimation()
			if not humanoid then
				warn("Humanoid не найден. Убедитесь, что персонаж загружен.")
				return
			end

			-- Находим и останавливаем анимацию
			if animationTrack then
				animationTrack:Stop()
				animationTrack:Destroy()
				animationTrack = nil
				animationIsPlaying = false -- Обновляем флаг
				print("Анимация остановлена.")
			else
				print("Анимация не запущена.")
			end
		end

		-- Функция для переключения анимации (запуск/остановка)
		local function ToggleAnimation()
			if animationIsPlaying then
				StopAnimation()
			else
				PlayAnimation()
			end
		end

		-- Обработка нажатия клавиши G
		UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
			if gameProcessedEvent then return end

			if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.G then
				ToggleAnimation()
			end
		end)

		-- Обработка респавна
		player.CharacterAdded:Connect(function(newCharacter)
			character = newCharacter
			humanoid = character:WaitForChild("Humanoid")
			task.wait(0.1) -- Небольшая задержка
			if animationIsPlaying then
				PlayAnimation() -- Перезапускаем анимацию, если она была включена до респавна
			end
		end)

		print("Скрипт запуска/остановки анимации активирован. Нажмите G для переключения.")
	end,
})


