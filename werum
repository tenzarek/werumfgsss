local Button = MainTab:CreateButton({
	Name = "руки отпервого лица",
	Callback = function()     
		-- Скрипт для отображения рук от первого лица

		local Players = game:GetService("Players")
		local RunService = game:GetService("RunService")
		local LocalPlayer = Players.LocalPlayer
		local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

		local LeftArmName = "Left Arm"
		local RightArmName = "Right Arm"

		local function MakeArmsVisible()
			local LeftArm = Character:FindFirstChild(LeftArmName)
			local RightArm = Character:FindFirstChild(RightArmName)

			if not LeftArm or not RightArm then
				return -- Если руки не найдены, выходим
			end

			-- Логика для отображения рук
			LeftArm.LocalTransparencyModifier = 0
			RightArm.LocalTransparencyModifier = 0
		end

		-- Функция для скрытия других частей тела
		local function HideBodyParts()
			for _, part in ipairs(Character:GetChildren()) do
				if part:IsA("BasePart") and part.Name ~= LeftArmName and part.Name ~= RightArmName then
					part.LocalTransparencyModifier = 0 -- Полная прозрачность
				end
			end
		end


		-- Функция для отслеживания добавления/удаления частей тела
		local function OnCharacterChanged()
			Character = LocalPlayer.Character
			if not Character then return end

			-- Изначально скрываем все, кроме рук
			HideBodyParts()
			MakeArmsVisible()

			-- Отслеживаем изменение внешнего вида
			Character.ChildAdded:Connect(function(child)
				if child:IsA("BasePart") and child.Name ~= LeftArmName and child.Name ~= RightArmName then
					child.LocalTransparencyModifier = 1 -- Скрываем добавленную часть тела
				end
				if child.Name == LeftArmName or child.Name == RightArmName then
					child.LocalTransparencyModifier = 0 --  Делаем руки видимыми, если они были добавлены
				end
			end)

			Character.ChildRemoved:Connect(function(child)
				-- Ничего не делаем при удалении (оставляем руки видимыми)
			end)

		end


		-- Подключаем функцию к RenderStepped для постоянного обновления
		local function UpdateArmsVisibility()
			if not LocalPlayer or not LocalPlayer.Character then return end
			Character = LocalPlayer.Character
			if not Character:FindFirstChild(LeftArmName) or not Character:FindFirstChild(RightArmName) then return end

			MakeArmsVisible() -- Убеждаемся, что руки видимы каждый кадр

		end


		-- Обрабатываем создание персонажа
		Players.PlayerAdded:Connect(function(player)
			player.CharacterAdded:Connect(OnCharacterChanged)
		end)

		if LocalPlayer and LocalPlayer.Character then
			OnCharacterChanged() -- Вызываем сразу, если персонаж уже есть
		end

		--Подключаем постоянное обновление видимости рук
		RunService.RenderStepped:Connect(UpdateArmsVisibility)
	end,
})

