local Button = MainTab:CreateButton({
	Name = "заспавнить какую то ебучую железяку в небе",
	Callback = function()     
		local player = game.Players.LocalPlayer

		if player then  -- Убедимся, что игрок существует
			local character = player.Character or player.CharacterAdded:Wait() -- Если персонаж еще не загружен, подождем его
			local rootPart = character:WaitForChild("HumanoidRootPart") -- Ждем HumanoidRootPart

			local offsetY1 = 150
			local offsetY2 = 60
			local offsetX = -10

			local function TeleportWithOffset(offsetY)
				if rootPart then  -- Убедимся, что HumanoidRootPart существует
					local currentPosition = rootPart.Position
					local newPosition = currentPosition + Vector3.new(offsetX, offsetY, 0)
					rootPart.CFrame = CFrame.new(newPosition)
				else
					print("HumanoidRootPart не найден!")
				end
			end

			TeleportWithOffset(offsetY1)
			TeleportWithOffset(offsetY2) -- Вызываем функцию для телепортации

		else
			print("Игрок не найден!")
		end

		print("Скрипт телепортации выполнен.")

		-- Скрипт для создания Truss на 500 студов вверх перед игроком

		local trussHeight = 5000000000000000000 -- Общая высота Truss
		local trussWidth = 200000000000000 -- Ширина Truss
		local trussDepth = 2 -- Глубина Truss
		local trussMaterial = Enum.Material.Metal -- Материал Truss
		local trussColor = Color3.fromRGB(100, 100, 100) -- Цвет Truss

		local function CreateTruss()
			local player = game.Players.LocalPlayer
			if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
				local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
				local head = player.Character:FindFirstChild("Head")
				if not head then
					print("Head не найден у персонажа.")
					return
				end

				local startPosition = rootPart.Position + head.CFrame.LookVector * 2 -- Начинаем немного перед игроком
				local endPosition = startPosition + Vector3.new(0, trussHeight, 0) -- Конечная позиция Truss

				local truss = Instance.new("TrussPart")
				truss.Name = "GeneratedTruss"
				truss.Size = Vector3.new(trussWidth, trussHeight, trussDepth)
				truss.Material = trussMaterial
				truss.Color = trussColor
				truss.Anchored = true
				truss.CanCollide = true
				-- Используем CFrame.new(position, lookAt) для правильной ориентации
				truss.CFrame = CFrame.new(startPosition, endPosition) * CFrame.Angles(math.rad(-90),0,0) --Поворот на 90 градусов
				truss.Parent = workspace

				print("Truss создана перед игроком.")
			else
				print("Персонаж не найден или HumanoidRootPart отсутствует.")
			end
		end

		CreateTruss()

		print("Скрипт создания Truss выполнен.")
	end,
})
