		local function UpdateRainbowHighlights()
			for _, object in pairs(workspace:GetDescendants()) do
				if object:IsA("Tool") then
					local highlight = object:GetAttribute("HighlightInstance")
					if highlight then
						local offset = tonumber(string.sub(tostring(object), 11, 14), 16) or 0
						local rainbowColor = GetRainbowColor(offset)
						highlight.FillColor = rainbowColor
						highlight.OutlineColor = rainbowColor
					end
				end
			end
		end

